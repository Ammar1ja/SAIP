{
  "name": "saip",
  "version": "1.0.0",
  "main": "lint-staged.config.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "build:auto": ". ./set-env.sh && next build",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings=100",
    "format": "prettier --write .",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "storybook:version": "node scripts/update-storybook-version.js",
    "storybook:version:help": "node scripts/update-storybook-version.js --help",
    "version:current": "node scripts/version-manager.cjs current",
    "version:list": "node scripts/version-manager.cjs list",
    "version:update": "node scripts/version-manager.cjs update",
    "version:config": "node scripts/version-manager.cjs config",
    "version:generate": "node scripts/version-manager.cjs generate",
    "version:help": "node scripts/version-manager.cjs help",
    "typecheck": "tsc --noEmit",
    "sitemap": "next-sitemap",
    "env:detect": "node scripts/branch-env-detector.js status",
    "env:generate": "node scripts/branch-env-detector.js generate",
    "dev:auto": "node scripts/branch-env-detector.js generate && next dev --turbo",
    "dev:test": "APACHE_SERVER_NAME=gp-saip-portals-website-backend-v3.test.internal.saip.gov.sa npm run env:generate && next dev --turbo",
    "dev:local": "rm -f .env.local && next dev --turbo"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next/bundle-analyzer": "^15.3.1",
    "@storybook/addon-interactions": "^9.0.0-alpha.10",
    "@storybook/manager-api": "^9.0.0-alpha.1",
    "@tanstack/react-query": "^5.71.1",
    "@xyflow/react": "^12.6.0",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.487.0",
    "moment": "^2.30.1",
    "moment-hijri": "^3.0.0",
    "next": "^16.2.4",
    "next-intl": "^4.0.2",
    "next-sitemap": "^4.2.3",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-day-picker": "^9.8.1",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.65.0",
    "react-multi-date-picker": "^4.5.2",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.1.0",
    "tailwind-scrollbar": "^4.0.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@chromatic-com/storybook": "^4.0.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.23.0",
    "@storybook/addon-a11y": "^9.0.11",
    "@storybook/addon-docs": "^9.0.11",
    "@storybook/addon-links": "^9.0.11",
    "@storybook/addon-onboarding": "^9.0.11",
    "@storybook/addon-vitest": "^9.0.11",
    "@storybook/nextjs": "^9.0.11",
    "@storybook/nextjs-vite": "^9.0.11",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.15",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitest/eslint-plugin": "^1.2.1",
    "@vitest/ui": "^3.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.23.0",
    "eslint-config-next": "^15.2.4",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-storybook": "^9.0.11",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "playwright": "^1.51.1",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "storybook": "^9.0.11",
    "tailwindcss": "^4.0.17",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "overrides": {
    "storybook": "$storybook"
  }
}
