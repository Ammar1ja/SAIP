# SAIP Environment Configuration
# This file is tracked in git — contains NO secrets.
# Jenkins pipeline should override NEXT_PUBLIC_SAIP_ENV per environment at build time.
# Local overrides (URLs, debug) go in .env.local (gitignored).

# Environment: development | test | staging | production
# Jenkins MUST set this at build time: NEXT_PUBLIC_SAIP_ENV=staging npm run build
NEXT_PUBLIC_SAIP_ENV=development

# Debug mode (disable in production)
NEXT_PUBLIC_DEBUG_MODE=false

# Use fallback data when Drupal API fails
NEXT_PUBLIC_USE_FALLBACK_DATA=true

NEXT_PUBLIC_EXTERNAL_STATISTICS_CATEGORIES=false

# Statistics API (external; used for IP statistics instead of Drupal field_statistics_items)
# NEXT_PUBLIC_STATISTICS_API_URL=https://your-statistics-api.example.com

# Cache settings
DRUPAL_API_CACHE_TIME=60
DRUPAL_API_TIMEOUT=30000
