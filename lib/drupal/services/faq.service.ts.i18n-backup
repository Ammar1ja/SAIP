export async function getFaqPageData(): Promise<FaqPageData> {
  try {
    const [categoriesResponse, questionsResponse] = await Promise.all([
      fetchFaqCategories(),
      fetchFaqQuestions(),
    ]);

    const categories = categoriesResponse.data;
    const questions = questionsResponse.data;

    if (categories.length === 0) {
      console.log('🔴 FAQ: No categories found, using fallback data');
      return getFaqFallbackData();
    }

    const data = transformFaqData(categories, questions);

    console.log('✅ FAQ: Using Drupal data');
    return data;
  } catch (error) {
    console.log('🔴 FAQ: Error fetching data, using fallback data');
    return getFaqFallbackData();
  }
}
