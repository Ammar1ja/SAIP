/**
 * FAQ Service
 * Handles data fetching and transformation for FAQ page
 */

import { fetchDrupal, extractText } from '../utils';
import { DrupalNode, DrupalIncludedEntity } from '../types';
import { DrupalResponse } from '../api-client';

// Frontend data interfaces
export interface FaqCategoryData {
  id: string;
  label: string;
  questions: FaqQuestionData[];
}

export interface FaqQuestionData {
  id: string;
  title: string;
  description: string;
}

export interface FaqPageData {
  heroHeading: string;
  heroSubheading: string;
  categories: FaqCategoryData[];
}

// Drupal API functions
export async function fetchFaqCategories(): Promise<DrupalResponse<DrupalNode>> {
  const endpoint = `/node/faq_category?filter[status]=1&sort=weight`;
  const response = await fetchDrupal<DrupalNode>(endpoint);
  return response;
}

export async function fetchFaqQuestions(): Promise<DrupalResponse<DrupalNode>> {
  const endpoint = `/node/faq_item?filter[status]=1&sort=weight`;
  const response = await fetchDrupal<DrupalNode>(endpoint);
  return response;
}

// Transformation functions
export function transformFaqData(categories: DrupalNode[], questions: DrupalNode[]): FaqPageData {
  // Group questions by category
  const categoriesMap = new Map<string, FaqCategoryData>();

  // Initialize categories
  categories.forEach((cat) => {
    const attrs = cat.attributes;
    categoriesMap.set(cat.id, {
      id: attrs.field_category_id || cat.id,
      label: attrs.title || 'Untitled Category',
      questions: [],
    });
  });

  // Add questions to categories
  questions.forEach((question) => {
    const attrs = question.attributes;
    const categoryData = question.relationships?.field_category?.data;
    const categoryId = categoryData && !Array.isArray(categoryData) ? categoryData.id : null;

    if (categoryId && categoriesMap.has(categoryId)) {
      const category = categoriesMap.get(categoryId)!;
      category.questions.push({
        id: attrs.field_question_id || question.id,
        title: attrs.title || attrs.field_question || 'Untitled Question',
        description: extractText(attrs.field_answer) || extractText(attrs.body) || '',
      });
    }
  });

  return {
    heroHeading: 'FAQs',
    heroSubheading: 'Find answers to frequently asked questions',
    categories: Array.from(categoriesMap.values()),
  };
}

