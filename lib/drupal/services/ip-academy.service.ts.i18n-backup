export async function getIPAcademyPageData(): Promise<IPAcademyData> {
  try {
    const response = await fetchIPAcademyPage();
    const nodes = response.data;
    const included = response.included || [];

    if (nodes.length === 0) {
      console.log('🔴 IP ACADEMY: Using fallback data ❌');
      return getIPAcademyFallbackData();
    }

    const node = nodes[0];
    const data = transformIPAcademyPage(node, included);
    console.log('🟢 IP ACADEMY: Using Drupal data ✅');
    return data;
  } catch (error) {
    console.log('🔴 IP ACADEMY: Using fallback data ❌');
    return getIPAcademyFallbackData();
  }
}
