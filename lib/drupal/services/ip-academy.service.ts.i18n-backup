import { fetchDrupal } from '../utils';
import { getRelated, getImageWithAlt, extractText } from '../utils';
import {
  DrupalIPAcademyPageNode,
  DrupalIncludedEntity,
  DrupalTrainingProgramNode,
  DrupalQualificationNode,
  DrupalEducationProjectNode,
  DrupalStatisticsItemNode,
  DrupalMediaTabNode,
} from '../types';
import { DrupalResponse } from '../api-client';

// Frontend interfaces
export interface IPAcademyData {
  heroHeading: string;
  heroSubheading: string;
  heroImage?: {
    src: string;
    alt: string;
  };
  overview: {
    statistics: {
      statistics: StatisticsCardData[];
      statisticsTitle: string;
      statisticsCtaLabel: string;
      statisticsCtaHref: string;
    };
  };
  trainingPrograms: TrainingProgramData[];
  qualifications: QualificationData[];
  educationProjects: EducationProjectData[];
  media: {
    heroTitle: string;
    heroDescription: string;
    heroImage: string;
    tabs: MediaTabData[];
    content: Record<string, MediaContentData>;
    filterFields: FilterFieldData[];
    badgeLabel: string;
  };
}

export interface StatisticsCardData {
  label: string;
  value?: number;
  chartType: string;
  chartData?: Array<{ value: number }>;
  trend?: {
    value: string;
    direction: string;
    description: string;
  };
  breakdown?: Array<{
    label: string;
    value: number;
    displayValue: string;
    color: string;
  }>;
}

export interface TrainingProgramData {
  id: string;
  title: string;
  description: string;
  details: string;
  forWhom: string;
  whatYouWillLearn: string[];
  startDate: string;
  duration: string;
  fees: string;
  language: string;
  location: string;
  faqHref: string;
  registerHref: string;
  courseFormat: string;
  courseMaterials: string;
  programme: Array<{
    id: string;
    title: string;
    subtitle: string;
    description: string;
  }>;
}

export interface QualificationData {
  id: string;
  title: string;
  description: string;
  details: string;
  forWhom: string[];
  requirements: string[];
  studyMaterialLabel: string;
  studyMaterialHref: string;
  examPrograms: Array<{
    id: string;
